<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/imgSPGioHang"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/logo" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtTenSPGioHang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nước ngọt Calpis"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnXoaItemGioHang"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#E57373" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtGiaSPGioHang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="12.000 đ"
            android:textColor="#999999"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnGiamSL"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#E0E0E0"
                android:padding="4dp"
                android:src="@android:drawable/button_onoff_indicator_off"
                app:tint="#666666" />

            <TextView
                android:id="@+id/txtSoLuongGioHang"
                android:layout_width="36dp"
                android:layout_height="28dp"
                android:background="#333333"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnTangSL"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#E0E0E0"
                android:padding="4dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#666666" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>